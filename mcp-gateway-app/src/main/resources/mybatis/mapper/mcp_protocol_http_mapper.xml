<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.laterya.ai.infrastructure.dao.IMcpProtocolHttpDao">

    <resultMap id="mcpProtocolHttpMap" type="cn.laterya.ai.infrastructure.dao.po.McpProtocolHttpPO">
        <id column="id" property="id"/>
        <result column="protocol_id" property="protocolId"/>
        <result column="http_url" property="httpUrl"/>
        <result column="http_method" property="httpMethod"/>
        <result column="http_headers" property="httpHeaders"/>
        <result column="timeout" property="timeout"/>
        <result column="retry_times" property="retryTimes"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <insert id="insert" parameterType="cn.laterya.ai.infrastructure.dao.po.McpProtocolHttpPO" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO mcp_protocol_http (protocol_id, http_url, http_method, http_headers, timeout, retry_times, status)
        VALUES (#{protocolId}, #{httpUrl}, #{httpMethod}, #{httpHeaders}, #{timeout}, #{retryTimes}, #{status})
    </insert>

    <delete id="deleteById">
        DELETE FROM mcp_protocol_http WHERE id = #{id}
    </delete>

    <update id="updateById" parameterType="cn.laterya.ai.infrastructure.dao.po.McpProtocolHttpPO">
        UPDATE mcp_protocol_http
        SET http_url = #{httpUrl}, http_method = #{httpMethod}, http_headers = #{httpHeaders},
            timeout = #{timeout}, retry_times = #{retryTimes}, status = #{status}
        WHERE id = #{id}
    </update>

    <select id="queryById" resultMap="mcpProtocolHttpMap">
        SELECT * FROM mcp_protocol_http WHERE id = #{id}
    </select>

    <select id="queryByProtocolId" resultMap="mcpProtocolHttpMap">
        SELECT * FROM mcp_protocol_http WHERE protocol_id = #{protocolId}
    </select>

    <select id="queryAll" resultMap="mcpProtocolHttpMap">
        SELECT * FROM mcp_protocol_http
    </select>

    <delete id="deleteByProtocolId">
        DELETE FROM mcp_protocol_http WHERE protocol_id = #{protocolId}
    </delete>

    <select id="queryPage" resultMap="mcpProtocolHttpMap">
        SELECT * FROM mcp_protocol_http
        <where>
            <if test="protocolId != null">AND protocol_id = #{protocolId}</if>
            <if test="httpUrl != null and httpUrl != ''">AND http_url LIKE CONCAT('%', #{httpUrl}, '%')</if>
        </where>
        ORDER BY id DESC
        LIMIT #{limit} OFFSET #{offset}
    </select>

    <select id="queryCount" resultType="long">
        SELECT COUNT(*) FROM mcp_protocol_http
        <where>
            <if test="protocolId != null">AND protocol_id = #{protocolId}</if>
            <if test="httpUrl != null and httpUrl != ''">AND http_url LIKE CONCAT('%', #{httpUrl}, '%')</if>
        </where>
    </select>

</mapper>
