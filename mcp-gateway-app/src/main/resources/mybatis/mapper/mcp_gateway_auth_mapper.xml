<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.laterya.ai.infrastructure.dao.IMcpGatewayAuthDao">

    <resultMap id="mcpGatewayAuthMap" type="cn.laterya.ai.infrastructure.dao.po.McpGatewayAuthPO">
        <id column="id" property="id"/>
        <result column="gateway_id" property="gatewayId"/>
        <result column="api_key" property="apiKey"/>
        <result column="rate_limit" property="rateLimit"/>
        <result column="expire_time" property="expireTime"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <insert id="insert" parameterType="cn.laterya.ai.infrastructure.dao.po.McpGatewayAuthPO" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO mcp_gateway_auth (gateway_id, api_key, rate_limit, expire_time, status)
        VALUES (#{gatewayId}, #{apiKey}, #{rateLimit}, #{expireTime}, #{status})
    </insert>

    <delete id="deleteById">
        DELETE FROM mcp_gateway_auth WHERE id = #{id}
    </delete>

    <update id="updateById" parameterType="cn.laterya.ai.infrastructure.dao.po.McpGatewayAuthPO">
        UPDATE mcp_gateway_auth
        SET api_key = #{apiKey}, rate_limit = #{rateLimit}, expire_time = #{expireTime}, status = #{status}
        WHERE id = #{id}
    </update>

    <select id="queryById" resultMap="mcpGatewayAuthMap">
        SELECT * FROM mcp_gateway_auth WHERE id = #{id}
    </select>

    <select id="queryByGatewayId" resultMap="mcpGatewayAuthMap">
        SELECT * FROM mcp_gateway_auth WHERE gateway_id = #{gatewayId}
    </select>

    <select id="queryByGatewayIdAndApiKey" resultMap="mcpGatewayAuthMap">
        SELECT * FROM mcp_gateway_auth
        WHERE gateway_id = #{gatewayId} AND api_key = #{apiKey} AND status = 1
        LIMIT 1
    </select>

    <select id="queryEffectiveGatewayAuthCount" resultType="int">
        SELECT COUNT(*) FROM mcp_gateway_auth WHERE gateway_id = #{gatewayId} AND status = 1
    </select>

    <select id="queryAll" resultMap="mcpGatewayAuthMap">
        SELECT * FROM mcp_gateway_auth
    </select>

</mapper>
